import java.util.LinkedList;

public class Traversinglinkedlist {
    public static void main(String[] args) {

        LinkedList<String> list = new LinkedList<>();

        list.add("Java");
        list.add("Python");
        list.add("C");

        // Traversing using for-each loop
        for(String s : list) {
            System.out.println(s);
        }
    }
}